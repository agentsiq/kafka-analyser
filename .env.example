# ── Required ──────────────────────────────────────────────────────────────────
# Shared PostgreSQL instance (same DB as alert-analyser and cur-analyser).
# Kafka-specific tables are created automatically on first startup.
DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/agentsiq

# Fernet key for encrypting stored secrets (api_key, sasl_password).
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
# Claude model for inference (default: claude-sonnet-4-6)
MODEL=claude-sonnet-4-6

# Platform backend for self-registration. Agent runs fully standalone if not set.
REGISTRY_URL=http://backend:8000
BACKEND_API_KEY=

# HTTP port (default: 8003)
PORT=8003

# ── NOT required ──────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY is intentionally omitted here.
# Set it via the Settings UI after startup — it is stored encrypted in PostgreSQL.
# For local dev without the platform, you may set it here as a fallback.
# ANTHROPIC_API_KEY=sk-ant-...

# ── Cache Backend ────────────────────────────────────────────────────────────
# Options: none (default), memory, redis
CACHE_BACKEND=none
# Required when CACHE_BACKEND=redis
CACHE_URL=redis://localhost:6379

# ── Vector Backend ───────────────────────────────────────────────────────────
# Options: none (default), pgvector, qdrant, pinecone
VECTOR_BACKEND=none
# Required when VECTOR_BACKEND=qdrant
VECTOR_URL=http://localhost:6333
# Required when VECTOR_BACKEND=pinecone
VECTOR_API_KEY=
# Collection/index name (default: kafka-analyser)
VECTOR_INDEX=kafka-analyser

# ── Graph Backend ────────────────────────────────────────────────────────────
# Options: none (default), neo4j
GRAPH_BACKEND=none
# Required when GRAPH_BACKEND=neo4j
GRAPH_URL=bolt://localhost:7687
GRAPH_USERNAME=neo4j
GRAPH_PASSWORD=
